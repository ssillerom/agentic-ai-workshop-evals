{
  "name": "langfuse-dad-it-support-workshop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "uv run python -m backend.server --reload",
    "build": "npm run build:client",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "uv run python -m backend.server",
    "prompt:publish": "uv run python -m scripts.publish_prompt",
    "dataset:seed": "uv run python -m scripts.seed_dataset",
    "dataset:run": "uv run python -m scripts.run_dataset"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "latest",
    "remark-gfm": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
